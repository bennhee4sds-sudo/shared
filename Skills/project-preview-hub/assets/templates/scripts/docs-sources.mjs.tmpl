import { readdirSync } from 'fs';
import { join } from 'path';

export const PROJECTS_ROOT = String.raw`__PROJECTS_ROOT__`;
export const IGNORED_PROJECT_NAMES = new Set([
  '__HUB_REPO_NAME__',
  'docs-hub',
  'P002_project-preview-hub',
  'shared',
  '_starlight-template',
  'archive',
  'archives',
  'backup',
  'backups',
  'tmp',
  'temp',
]);

export const IGNORED_PROJECT_PREFIXES = [
  '__tmp',
  '__',
  '_tmp',
  '_archive',
  '_backup',
];

export function isIgnoredProjectName(name) {
  return (
    IGNORED_PROJECT_NAMES.has(name) ||
    name.startsWith('.') ||
    IGNORED_PROJECT_PREFIXES.some((prefix) => name.startsWith(prefix))
  );
}

export function slugifySegment(value) {
  return value
    .trim()
    .toLowerCase()
    .replace(/['"]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    || 'project';
}

export function discoverDocsSources(root = PROJECTS_ROOT) {
  return readdirSync(root, { withFileTypes: true })
    .filter((entry) => entry.isDirectory())
    .filter((entry) => !isIgnoredProjectName(entry.name))
    .map((entry) => ({
      src: join(root, entry.name),
      slug: slugifySegment(entry.name),
      label: entry.name,
    }))
    .sort((a, b) => a.label.localeCompare(b.label));
}

export const docsSources = discoverDocsSources();
